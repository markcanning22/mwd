.project-container {
    padding: 16px;

    & .project {
        width: 50%;
        display: inline-block;
        padding: 16px;
        box-sizing: border-box;

        & .project__name {
            display: inline-block;
            margin: 8px 0 16px 0;
            font-weight: 300;
        }

        & .project__image {
            width: 100%;
            height: 500px;
            object-fit: cover;

            &:hover {
                opacity: 0.9;
            }
        }
    }
}